{
  "name": "company-docs-rag",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "lint": "pnpm --filter backend lint && pnpm --filter frontend lint",
    "build": "pnpm -r build",
    "verify:local": "pnpm --filter backend verify:local"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild", "vue-demi"]
  }
}
