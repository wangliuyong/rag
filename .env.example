# DashScope（通义千问）https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=company_docs

# 向量维度（需与 text-embedding-v3 配置一致，默认 1024）
EMBEDDING_DIMENSIONS=1024

# 服务端
PORT=3001
HOST=0.0.0.0
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# 初始管理员（首次启动时若 users 表为空则创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 数据目录（相对 backend 工作目录）
DATA_DIR=./data
